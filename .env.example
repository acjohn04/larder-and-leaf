# --- Core Configuration ---
# Your Google Gemini API Key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=""

# Prisma connection string (defaults to local SQLite)
DATABASE_URL="file:./dev.db"


# --- Authentication (Auth.js / NextAuth) ---
# Generate a secret: openssl rand -base64 32
AUTH_SECRET=""
AUTH_TRUST_HOST="true"
AUTH_URL="http://localhost:3000"

# GitHub Provider
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""

# Google Provider
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""


# --- Development & Testing Flags ---
# Set to "true" to bypass real auth and use a synthetic "Demo User"
DEMO_MODE="false"
NEXT_PUBLIC_DEMO_MODE="false"

# Set to "true" to return mock data from the Vision API
USE_MOCK_GEMINI="false"
