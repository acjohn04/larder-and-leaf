generator client {
  provider = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "sqlite"
}

model InventoryItem {
  id              String    @id @default(cuid())
  name            String
  category        String
  quantity        Float     @default(0)
  unit            String    @default("units")
  confidenceScore Float?
  expiresAt       DateTime?
  minThreshold    Float     @default(0)
  addedAt         DateTime  @default(now())
}
